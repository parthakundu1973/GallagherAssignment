{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5170",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        // "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/calculation-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level}] {Message}{NewLine}{Exception}"
        }
      }
    ]
  },
  //ProbabilityOperationChoiceItems is provide  for Flexibily to change Lebel Operation Choice , You can Easily Add new Choice without changing Frontend. Plesae Do not change the key.
  //If you need to add new Item , Plesae Add Here and add Calculation  in Domain/Service Folder, Front end will pick up Automaticlly.

  "ProbabilityOperationChoiceItems": {
    "Operations": [
      {
        "Key": "CombinedWith",
        "Label": "CombinedWith: P(A)P(B)"
      },
      {
        "Key": "Either",
        "Label": "Either: P(A) + P(B) – P(A)P(B)"
      }
    ]
  }
} 
